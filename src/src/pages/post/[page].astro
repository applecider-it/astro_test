---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';
import type { Post } from '@/types/types';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts: Post[] = await getCollection('post');

  console.log(posts);

  posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return paginate(posts, { pageSize: 2 });
};

const { page } = Astro.props as { page: Page<Post> };
---

<Layout>
  <section class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold mb-12">Blog</h1>

    <div class="grid md:grid-cols-2 gap-8">
      {
        page.data.map((post: Post) => (
          <a
            href={`/article/${post.slug}`}
            class="block bg-white rounded-2xl shadow hover:shadow-xl transition p-6"
          >
            <h2 class="text-xl font-semibold mb-2">{post.data.title}</h2>

            <p class="text-sm text-gray-500 mb-4">
              {post.data.date.toLocaleDateString()}
            </p>

            <p class="text-gray-600 mb-4">{post.data.description}</p>

            <div class="flex gap-2 flex-wrap">
              {post.data.tags?.map((tag) => (
                <span class="app-tag">#{tag}</span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <nav class="flex justify-center items-center gap-3 mt-16">
    {
      page.url.prev && (
        <a
          href={page.url.prev}
          class="px-4 py-2 rounded-xl border border-gray-200 hover:bg-gray-100 transition"
        >
          ← Prev
        </a>
      )
    }

    {
      Array.from({ length: page.lastPage }).map((_, i) => {
        const pageNumber = i + 1;
        const url = `/post/${pageNumber}`;
        const isActive = pageNumber === page.currentPage;

        return (
          <a
            href={url}
            class={`px-4 py-2 rounded-xl transition
        ${
          isActive
            ? 'bg-black text-white shadow'
            : 'border border-gray-200 hover:bg-gray-100'
        }`}
          >
            {pageNumber}
          </a>
        );
      })
    }

    {
      page.url.next && (
        <a
          href={page.url.next}
          class="px-4 py-2 rounded-xl border border-gray-200 hover:bg-gray-100 transition"
        >
          Next →
        </a>
      )
    }
  </nav>
</Layout>
